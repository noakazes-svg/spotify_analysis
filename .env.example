# ── Spotify OAuth ──────────────────────────────────────────────────────────────
# Get from https://developer.spotify.com/dashboard → create app
# Set Redirect URI to: http://localhost:8000/api/v1/auth/spotify/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:8000/api/v1/auth/spotify/callback

# ── Genius API ─────────────────────────────────────────────────────────────────
# Get from https://genius.com/api-clients
GENIUS_ACCESS_TOKEN=your_genius_access_token

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Security ────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production-too

# ── Database ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spotify_intel

# ── Redis ───────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App ─────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
DEBUG=true
